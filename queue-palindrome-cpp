#include <iostream>
#include <queue>
using namespace std;

int main() {
    string kata;
    queue<char> q;

    cout << "Input: ";
    cin >> kata;

    // Masukkan semua karakter ke queue
    for (char c : kata) {
        q.push(c);
    }

    bool palindrome = true;

    // Bandingkan dari belakang
    for (int i = kata.length() - 1; i >= 0; i--) {
        if (kata[i] != q.front()) {
            palindrome = false;
            break;
        }
        q.pop();
    }

    // Output
    if (palindrome) {
        cout << "Queue adalah palindrome" << endl;
    } else {
        cout << "Queue bukan palindrome" << endl;
    }

    return 0;
}
